---
import Base from '../layouts/Base.astro';
import SolarSystem from '../components/SolarSystem.vue';
---

<Base hideNav={true}>
  <SolarSystem client:only="vue" />
</Base>

<script>
  import { navigate } from 'astro:transitions/client';

  // 监听 SolarSystem 发出的 planet-click 事件，使用 navigate() 导航保留过渡动画
  document.addEventListener('planet-click', ((e: CustomEvent) => {
    const url = e.detail?.url;
    if (url && typeof url === 'string') {
      document.documentElement.classList.add('solar-exit');
      navigate(url);
    }
  }) as EventListener);
</script>

