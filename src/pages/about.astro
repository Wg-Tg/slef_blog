---
import Base from '../layouts/Base.astro';
import ScrollReveal from '../components/ScrollReveal.vue';

// TODO: REPLACE_ME — 替换为你的个人信息
const siteOwner = {
  name: 'Your Name',
  tagline: '写代码、拍照片、探索世界。',
  skills: ['TypeScript', 'Vue.js', 'React', 'Node.js', 'Python', 'Figma'],
  projects: [
    { title: 'Project Alpha', desc: 'An open-source developer tool.', url: 'https://github.com/WG-TG' },
    { title: 'Project Beta', desc: 'A creative WebGL experiment.', url: 'https://github.com/WG-TG' },
  ],
  social: [
    { label: 'GitHub', url: 'https://github.com/WG-TG' },
    { label: 'Twitter', url: 'https://twitter.com/' },
    { label: 'Email', url: 'mailto:hello@example.com' },
  ],
};
---

<Base title="About" description="关于我">
  <div class="content-container py-16">
    <!-- 头像 + 简介 -->
    <ScrollReveal client:load>
      <div class="about-hero">
        <div class="avatar-box">
          <!-- TODO: REPLACE_ME — 替换头像图片 -->
          <svg viewBox="0 0 100 100" class="avatar-svg">
            <rect width="100" height="100" rx="20" fill="#F0EDEB"/>
            <circle cx="50" cy="38" r="16" fill="#D4C8C0"/>
            <ellipse cx="50" cy="78" rx="24" ry="20" fill="#D4C8C0"/>
          </svg>
        </div>
        <div>
          <h1 class="about-name">{siteOwner.name}</h1>
          <p class="about-tagline">{siteOwner.tagline}</p>
        </div>
      </div>
    </ScrollReveal>

    <!-- 技能 -->
    <ScrollReveal client:load :delay="0.1">
      <section class="mt-16">
        <h2 class="section-title">Skills</h2>
        <div class="skill-cloud">
          {siteOwner.skills.map((s) => <span class="skill-badge">{s}</span>)}
        </div>
      </section>
    </ScrollReveal>

    <!-- 项目 -->
    <ScrollReveal client:load :delay="0.15">
      <section class="mt-16">
        <h2 class="section-title">Projects</h2>
        <div class="project-grid">
          {siteOwner.projects.map((p) => (
            <a href={p.url} target="_blank" rel="noopener" class="project-card">
              <h3 class="project-title">{p.title}</h3>
              <p class="project-desc">{p.desc}</p>
              <span class="project-link">→ 查看项目</span>
            </a>
          ))}
        </div>
      </section>
    </ScrollReveal>

    <!-- 社交 -->
    <ScrollReveal client:load :delay="0.2">
      <section class="mt-16">
        <h2 class="section-title">Connect</h2>
        <div class="social-links">
          {siteOwner.social.map((l) => (
            <a href={l.url} target="_blank" rel="noopener" class="social-link">{l.label}</a>
          ))}
        </div>
      </section>
    </ScrollReveal>
  </div>
</Base>

<style>
  .about-hero {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .avatar-box {
    width: 7rem; height: 7rem;
    flex-shrink: 0;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    background: linear-gradient(135deg, #F5F0F0 0%, #EDE8F0 100%);
  }
  .avatar-svg { width: 100%; height: 100%; display: block; }
  .about-name {
    font-size: 2.8rem; margin-bottom: 0.25rem;
    background: linear-gradient(135deg, var(--color-text) 0%, var(--color-accent-deep) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .about-tagline {
    color: var(--color-text-light);
    font-size: 1.1rem; margin: 0; font-weight: 300;
  }
  .section-title {
    font-size: 1.4rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border-light);
    color: var(--color-accent-deep);
  }
  .skill-cloud {
    display: flex; flex-wrap: wrap; gap: 0.6rem;
  }
  .skill-badge {
    font-size: 0.85rem; font-weight: 400;
    padding: 0.45rem 1rem;
    border-radius: 2rem;
    background: linear-gradient(135deg, rgba(126,184,218,0.12) 0%, rgba(184,169,212,0.12) 100%);
    color: var(--color-accent-deep);
    border: 1px solid rgba(126,184,218,0.2);
    transition: all 0.2s;
    cursor: default;
  }
  .skill-badge:hover {
    background: linear-gradient(135deg, rgba(126,184,218,0.2) 0%, rgba(184,169,212,0.2) 100%);
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }
  .project-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem;
  }
  .project-card {
    display: block;
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    text-decoration: none;
    color: var(--color-text);
    transition: all 0.3s var(--ease-out);
    box-shadow: var(--shadow-sm);
  }
  .project-card:hover {
    box-shadow: var(--shadow-hover);
    border-color: var(--color-accent);
    transform: translateY(-2px);
    text-decoration: none;
  }
  .project-title {
    font-size: 1.1rem; font-weight: 600; margin-bottom: 0.4rem;
    font-family: var(--font-body);
  }
  .project-desc {
    color: var(--color-text-light); font-size: 0.9rem; margin-bottom: 0.75rem;
  }
  .project-link {
    font-size: 0.85rem; color: var(--color-accent-deep); font-weight: 500;
  }
  .social-links {
    display: flex; flex-wrap: wrap; gap: 1.5rem;
  }
  .social-link {
    font-size: 1rem; font-weight: 500;
    color: var(--color-text);
    padding-bottom: 2px;
    border-bottom: 1.5px solid var(--color-accent-pink);
    transition: all 0.2s;
    text-decoration: none;
  }
  .social-link:hover {
    color: var(--color-accent-purple);
    border-bottom-color: var(--color-accent-purple);
    text-decoration: none;
  }
</style>
