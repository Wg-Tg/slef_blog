---
import Base from '../layouts/Base.astro';
import ScrollReveal from '../components/ScrollReveal.vue';

// TODO: REPLACE_ME — 替换为你的个人信息
const siteOwner = {
  name: 'Your Name',
  tagline: '一个在数字宇宙中探索的人。',
  avatar: '/placeholder-avatar.svg',
  skills: ['TypeScript', 'Vue.js', 'React', 'Node.js', 'Python', 'Figma'],
  projects: [
    {
      title: 'Project Alpha',
      description: 'An open-source tool for developers.',
      url: 'https://github.com/WG-TG',
    },
    {
      title: 'Project Beta',
      description: 'A creative web experiment with WebGL.',
      url: 'https://github.com/WG-TG',
    },
  ],
  social: [
    { label: 'GitHub', url: 'https://github.com/WG-TG' },
    { label: 'Twitter', url: 'https://twitter.com/' },
    { label: 'Email', url: 'mailto:hello@example.com' },
  ],
};
---

<Base title="About" description="关于我">
  <div class="content-container py-16">
    <!-- Section: Avatar & Intro -->
    <ScrollReveal client:load>
      <section class="mb-16">
        <div class="flex flex-col sm:flex-row items-start gap-8">
          <!-- Avatar Placeholder -->
          <div class="w-32 h-32 flex-shrink-0 bg-muted/20 border-2 border-border shadow-[6px_6px_0px_#2B2B2B] flex items-center justify-center overflow-hidden">
            <!-- TODO: REPLACE_ME — replace with your real avatar image -->
            <svg viewBox="0 0 100 100" class="w-full h-full">
              <rect width="100" height="100" fill="#E5E5E5" />
              <circle cx="50" cy="38" r="16" fill="#9E9E9E" />
              <ellipse cx="50" cy="78" rx="24" ry="20" fill="#9E9E9E" />
            </svg>
          </div>

          <div>
            <h1 class="text-4xl! sm:text-4.5rem! mb-2">{siteOwner.name}</h1>
            <p class="text-muted text-lg m-0">{siteOwner.tagline}</p>
          </div>
        </div>
      </section>
    </ScrollReveal>

    <!-- Section: Skills -->
    <ScrollReveal client:load delay={0.1}>
      <section class="mb-16">
        <h2 class="mb-6">Skills</h2>
        <div class="flex flex-wrap gap-3">
          {siteOwner.skills.map((skill) => (
            <span class="skill-tag">
              {skill}
            </span>
          ))}
        </div>
      </section>
    </ScrollReveal>

    <!-- Section: Projects -->
    <ScrollReveal client:load delay={0.2}>
      <section class="mb-16">
        <h2 class="mb-6">Projects</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {siteOwner.projects.map((project) => (
            <a href={project.url} target="_blank" rel="noopener" class="card card-hover no-underline! text-text">
              <h3 class="text-lg! mb-2">{project.title}</h3>
              <p class="text-muted text-sm m-0">{project.description}</p>
              <span class="inline-block mt-3 font-mono text-xs text-accent">→ View Project</span>
            </a>
          ))}
        </div>
      </section>
    </ScrollReveal>

    <!-- Section: Social Links -->
    <ScrollReveal client:load delay={0.3}>
      <section>
        <h2 class="mb-6">Connect</h2>
        <div class="flex flex-wrap gap-6">
          {siteOwner.social.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener"
              class="social-link"
            >
              {link.label}
            </a>
          ))}
        </div>
      </section>
    </ScrollReveal>
  </div>
</Base>

<style>
  .skill-tag {
    font-family: var(--font-mono, monospace);
    font-size: 0.85rem;
    font-weight: 500;
    padding: 6px 16px;
    border: 2px solid var(--color-accent, #E63946);
    background: var(--color-surface, #FFFFFF);
    color: var(--color-text, #1A1A1A);
    transition: all 0.15s ease;
    cursor: default;
    user-select: none;
  }

  .skill-tag:hover {
    background: var(--color-accent, #E63946);
    color: #FFFFFF;
  }

  .social-link {
    font-family: var(--font-heading, 'DM Sans', sans-serif);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text, #1A1A1A);
    text-decoration: none;
    position: relative;
    padding-bottom: 2px;
    transition: color 0.2s ease;
  }

  .social-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 0;
    height: 2px;
    background: var(--color-accent, #E63946);
    transition: width 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .social-link:hover {
    color: var(--color-accent, #E63946);
    text-decoration: none;
  }

  .social-link:hover::after {
    width: 100%;
  }
</style>
