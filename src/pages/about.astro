---
import Base from '../layouts/Base.astro';
import ScrollReveal from '../components/ScrollReveal.vue';
import ContactTabs from '../components/ContactTabs.vue';

const siteOwner = {
  name: 'L',
  tagline: '踢球是生活，coding也是。',
  skills: ['SpringBoot', 'Mybatis', 'Vue', 'Python', 'FastAPI', 'MySQL','......'],
};

const hobbyList = [
  { title: '足球', desc: '绿茵场上奔跑，团队配合的快感无与伦比。', icon: '⚽', color: '#7EB8DA' },
  { title: '编程', desc: '用代码构建世界，从后端到前端，不断探索新技术。', icon: '💻', color: '#B8A9D4' },
  { title: '游戏', desc: '从主机到 PC，游戏是另一种探索世界的方式。', icon: '🎮', color: '#D4A5C4' },
  { title: '音乐', desc: '旋律是最好的陪伴，吉他和播放列表是日常。', icon: '🎸', color: '#C4A8D0' },
];
---

<Base title="About" description="关于我">
  <div class="content-container py-16">
    <!-- 头像 + 简介 -->
    <ScrollReveal client:load>
      <div class="about-hero">
        <div class="avatar-box">
          <img src="/avatar.jpg" alt="Avatar" class="avatar-img" />
        </div>
        <div>
          <h1 class="about-name">{siteOwner.name}</h1>
          <p class="about-tagline">{siteOwner.tagline}</p>
        </div>
      </div>
    </ScrollReveal>

    <!-- 技能 -->
    <ScrollReveal client:load :delay="0.1">
      <section class="mt-16">
        <h2 class="section-title">Skills</h2>
        <div class="skill-cloud">
          {siteOwner.skills.map((s) => <span class="skill-badge">{s}</span>)}
        </div>
      </section>
    </ScrollReveal>

    <!-- 爱好 -->
    <ScrollReveal client:load :delay="0.15">
      <section class="mt-16">
        <h2 class="section-title">Hobbies</h2>
        <div class="hobby-grid">
          {hobbyList.map((h) => (
            <div class="hobby-card">
              <div class="hobby-icon" style={`background: ${h.color}15; color: ${h.color}`}>
                {h.icon}
              </div>
              <h3>{h.title}</h3>
              <p>{h.desc}</p>
            </div>
          ))}
        </div>
      </section>
    </ScrollReveal>

    <!-- 社交 -->
    <ScrollReveal client:load :delay="0.2">
      <section class="mt-16">
        <h2 class="section-title">Connect</h2>
        <ContactTabs client:load githubUser="WG-TG" />
      </section>
    </ScrollReveal>
  </div>
</Base>

<style>
  .about-hero {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .avatar-box {
    width: 7rem; height: 7rem;
    flex-shrink: 0;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    background: linear-gradient(135deg, #F5F0F0 0%, #EDE8F0 100%);
  }
  .avatar-img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
  }
  .about-name {
    font-size: 2.8rem; margin-bottom: 0.25rem;
    background: linear-gradient(135deg, var(--color-text) 0%, var(--color-accent-deep) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .about-tagline {
    color: var(--color-text-light);
    font-size: 1.1rem; margin: 0; font-weight: 300;
  }
  .section-title {
    font-size: 1.4rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border-light);
    color: var(--color-accent-deep);
  }
  .skill-cloud {
    display: flex; flex-wrap: wrap; gap: 0.6rem;
  }
  .skill-badge {
    font-size: 0.85rem; font-weight: 400;
    padding: 0.45rem 1rem;
    border-radius: 2rem;
    background: linear-gradient(135deg, rgba(126,184,218,0.12) 0%, rgba(184,169,212,0.12) 100%);
    color: var(--color-accent-deep);
    border: 1px solid rgba(126,184,218,0.2);
    transition: all 0.2s;
    cursor: default;
  }
  .skill-badge:hover {
    background: linear-gradient(135deg, rgba(126,184,218,0.2) 0%, rgba(184,169,212,0.2) 100%);
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }
  .hobby-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
  }
  .hobby-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    text-align: center;
    transition: all 0.3s var(--ease-out);
    box-shadow: var(--shadow-sm);
  }
  .hobby-card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-2px);
    border-color: var(--color-accent);
  }
  .hobby-icon {
    width: 3rem; height: 3rem;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.5rem;
    margin: 0 auto 0.75rem;
  }
  .hobby-card h3 {
    font-family: var(--font-body);
    font-size: 0.95rem; font-weight: 600;
    margin-bottom: 0.3rem;
  }
  .hobby-card p {
    font-size: 0.8rem; color: var(--color-text-light);
    line-height: 1.6; margin: 0;
    font-weight: 300;
  }
</style>
