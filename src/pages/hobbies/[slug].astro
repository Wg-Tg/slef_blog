---
import Base from '../../layouts/Base.astro';
import ScrollReveal from '../../components/ScrollReveal.vue';

export async function getStaticPaths() {
  const hobbiesDetail: Record<string, {
    title: string; icon: string; color: string;
    intro: string;
    sections: { heading: string; body: string }[];
  }> = {
    football: {
      title: '足球', icon: '⚽', color: '#7EB8DA',
      intro: '绿茵场上奔跑，团队配合的快感无与伦比。足球不只是一项运动，更是一种生活方式。',
      sections: [
        { heading: '热爱的球队', body: '每一场比赛都是一次新的冒险。喜欢看国内小将们的足球赛事。' },
        { heading: '踢球经历', body: '从初中开始和朋友们一起踢球，最享受的是配合进球那一刻的默契和热血。偏爱前场，干就完事。' },
        { heading: '感悟', body: '足球教会我团队合作的重要性——一个人再强也赢不了比赛。这和写代码很像，好的团队配合能创造出超出个人能力的东西。' },
      ],
    },
    gaming: {
      title: '游戏', icon: '🎮', color: '#D4A5C4',
      intro: '从主机到 PC，游戏是另一种探索世界的方式。每一款游戏都是一次不同人生的体验。',
      sections: [
        { heading: '喜欢的类型', body: '偏爱 MOBA与FPS 类游戏，喜欢激烈的战斗和需要思考的玩法。偶尔也玩 模拟经营 放松心情。' },
        { heading: '游戏哲学', body: '好的游戏像一本可以交互的小说。它不仅仅是娱乐，更是艺术、叙事和技术的结合体。' },
        { heading: '游戏与编程', body: '玩游戏让我对交互设计有了更深的理解。很多前端动画和用户体验的灵感都来源于游戏 UI。' },
      ],
    },
    opensource: {
      title: '编码', icon: '💻', color: '#B8A9D4',
      intro: '喜欢自己动手写点独立小项目，从后端到前端，享受把一个想法变成现实的成就感。',
      sections: [
        { heading: '技术栈', body: '主要用 SpringBoot + MyBatis-Plus 写后端，Vue 3 写前端，MySQL 做数据存储。最近也在接触 FastAPI 和 Dify 做 AI 相关的应用。' },
        { heading: '项目经历', body: '写过个人博客系统、宠物管理系统、健康数据平台等小项目。每一个项目都让我对前后端协作和项目架构有了更深的理解。' },
        { heading: '理念', body: '不追求多么高深的技术，先把基础链路跑通，把最常用的东西吃透。从能跑，到能看懂流程，再到能独立复制——这是我的学习节奏。' },
      ],
    },
    hiking: {
      title: '徒步', icon: '🥾', color: '#5A9FC0',
      intro: '山野之间是最好的冥想空间。远离屏幕，只听到风、鸟鸣和自己的脚步声。',
      sections: [
        { heading: '常去的路线', body: '冬天的武功山，雪景美不胜收，夏天的武功山，充满激情。' },
        { heading: '装备', body: '一群熟悉的朋友是不可多得的‘装备’。' },
        { heading: '感悟', body: '登山的过程像编程——每一步都算数，急不得。到达山顶的满足感很短暂，真正的收获在攀登的过程中。' },
      ],
    },
    music: {
      title: '音乐', icon: '🎸', color: '#C4A8D0',
      intro: '音乐是时间的艺术。三分钟的旋律可以承载一生的情感。',
      sections: [
        { heading: '乐器', body: '好好的吉他愣是很久在我手上变成了烧火棍' },
        { heading: '听什么', body: '巴拉莱卡，这个我给到夯' },
        { heading: '音乐与代码', body: '写代码时听听纯音乐，那是指尖与心灵的对话。' },
      ],
    },
  };

  return Object.keys(hobbiesDetail).map((slug) => ({
    params: { slug },
    props: { hobby: hobbiesDetail[slug] },
  }));
}

const { hobby } = Astro.props;
---

<Base title={`${hobby.title} — Hobbies`} description={hobby.intro}>
  <div class="content-container py-16">
    <ScrollReveal client:load>
      <a href="/hobbies" class="back-link">← 返回爱好</a>
      <header class="detail-header">
        <span class="detail-icon" style={`background: ${hobby.color}18; color: ${hobby.color}`}>{hobby.icon}</span>
        <h1>{hobby.title}</h1>
        <p class="detail-intro">{hobby.intro}</p>
      </header>
    </ScrollReveal>

    {hobby.sections.map((s, i) => (
      <ScrollReveal client:load delay={i * 0.08}>
        <section class="detail-section">
          <h2>{s.heading}</h2>
          <p>{s.body}</p>
        </section>
      </ScrollReveal>
    ))}
  </div>
</Base>

<style>
  .back-link {
    display: inline-block; margin-bottom: 2rem;
    font-size: 0.9rem; color: var(--color-text-light);
    text-decoration: none; transition: color 0.2s;
  }
  .back-link:hover { color: var(--color-accent-deep); }
  .detail-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border-light);
  }
  .detail-icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 4rem; height: 4rem; border-radius: 50%;
    font-size: 2rem; margin-bottom: 1rem;
  }
  .detail-header h1 { margin-bottom: 0.5rem; }
  .detail-intro {
    color: var(--color-text-light);
    font-size: 1.1rem; line-height: 1.8;
    font-weight: 300; max-width: 600px;
  }
  .detail-section {
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }
  .detail-section h2 {
    font-family: var(--font-body);
    font-size: 1.1rem; font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--color-accent-deep);
  }
  .detail-section p {
    font-size: 0.95rem; line-height: 1.85;
    color: var(--color-text);
    margin: 0;
  }
</style>
