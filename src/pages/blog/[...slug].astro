---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ScrollReveal from '../../components/ScrollReveal.vue';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Base title={post.data.title} description={post.data.description}>
  <div class="content-container py-16">
    <ScrollReveal client:load>
      <header class="article-header">
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="article-tags">
            {post.data.tags.map((t) => <span class="article-tag">#{t}</span>)}
          </div>
        )}
        <h1 class="article-title">{post.data.title}</h1>
        <p class="article-desc">{post.data.description}</p>
        <time class="article-date" datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </header>
    </ScrollReveal>

    <ScrollReveal client:load :delay="0.1">
      <article class="prose">
        <Content />
      </article>
    </ScrollReveal>

    <hr />

    <ScrollReveal client:load :delay="0.2">
      <div id="comments">
        <h3 class="comment-heading">Comments</h3>
        <p class="comment-placeholder">Loading comments...</p>
      </div>
    </ScrollReveal>
  </div>
</Base>

<script>
  if (typeof window !== 'undefined') {
    const s = document.createElement('script');
    s.src = 'https://giscus.app/client.js';
    s.setAttribute('data-repo', 'WG-TG/slef_blog');
    s.setAttribute('data-repo-id', 'R_kgDOO');     // TODO: REPLACE_ME
    s.setAttribute('data-category', 'Announcements');
    s.setAttribute('data-category-id', 'DIC_kwDOO'); // TODO: REPLACE_ME
    s.setAttribute('data-mapping', 'pathname');
    s.setAttribute('data-strict', '0');
    s.setAttribute('data-reactions-enabled', '1');
    s.setAttribute('data-emit-metadata', '0');
    s.setAttribute('data-input-position', 'bottom');
    s.setAttribute('data-theme', 'light');
    s.setAttribute('data-lang', 'zh-CN');
    s.setAttribute('crossorigin', 'anonymous');
    s.async = true;
    s.onload = () => { document.querySelector('#comments .comment-placeholder')?.remove(); };
    document.getElementById('comments')?.appendChild(s);
  }
</script>

<style>
  .article-header { margin-bottom: 2.5rem; }
  .article-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 0.75rem; }
  .article-tag {
    font-family: var(--font-mono); font-size: 0.72rem;
    color: var(--color-accent-purple);
    background: rgba(184,169,212,0.1);
    padding: 0.15rem 0.5rem; border-radius: 4px;
  }
  .article-title { margin-bottom: 0.5rem; }
  .article-desc {
    color: var(--color-text-light); font-size: 1.1rem;
    margin-bottom: 0.5rem; font-weight: 300;
  }
  .article-date {
    font-family: var(--font-mono); font-size: 0.8rem; color: var(--color-text-light);
  }
  .comment-heading {
    font-family: var(--font-body); font-size: 1.1rem;
    font-weight: 600; margin-bottom: 1rem;
  }
  .comment-placeholder {
    color: var(--color-text-light); font-size: 0.9rem;
  }

  /* Prose */
  .prose {
    font-size: 1.05rem; line-height: 1.9; color: var(--color-text);
  }
  .prose :global(h2) { margin-top: 2.5rem; margin-bottom: 0.75rem; }
  .prose :global(h3) { margin-top: 2rem; margin-bottom: 0.5rem; }
  .prose :global(p) { margin-bottom: 1.5em; }
  .prose :global(ul), .prose :global(ol) { padding-left: 1.5rem; margin-bottom: 1.5em; }
  .prose :global(li) { margin-bottom: 0.3em; }
  .prose :global(pre) { margin: 1.5rem 0; }
  .prose :global(blockquote) {
    font-style: italic; border-left: 3px solid var(--color-accent-pink);
    padding: 0.5rem 1rem; margin: 1.5rem 0;
    background: linear-gradient(135deg, rgba(212,165,196,0.06) 0%, rgba(184,169,212,0.06) 100%);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }
  .prose :global(img) {
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
  }
</style>
