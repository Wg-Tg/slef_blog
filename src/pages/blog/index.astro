---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ScrollReveal from '../../components/ScrollReveal.vue';

const posts = await getCollection('blog');
const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Base title="Blog" description="博客文章">
  <div class="content-container py-16">
    <div class="page-header">
      <h1>Blog</h1>
      <p>文章是思想的沉淀。<br/><a href="https://blog.csdn.net/2401_83519807" target="_blank" rel="noopener" class="csdn-link">更多文章在 CSDN →</a></p>
    </div>

    <div class="post-list">
      {sortedPosts.map((post, i) => (
        <ScrollReveal client:load delay={i * 0.08}>
          <a href={`/blog/${post.id}`} class="post-card">
            <div class="post-date">
              <span class="post-day">{post.data.date.getDate()}</span>
              <span class="post-month">
                {post.data.date.toLocaleDateString('zh-CN', { month: 'short', year: 'numeric' })}
              </span>
            </div>
            <div class="post-info">
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-desc">{post.data.description}</p>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="post-tags">
                  {post.data.tags.map((t) => <span class="post-tag">#{t}</span>)}
                </div>
              )}
            </div>
          </a>
        </ScrollReveal>
      ))}
    </div>
  </div>
</Base>

<style>
  .page-header { margin-bottom: 2.5rem; }
  .page-header h1 { margin-bottom: 0.3rem; }
  .page-header p { color: var(--color-text-light); font-size: 1.1rem; font-weight: 300; }
  .csdn-link {
    color: var(--color-accent-purple);
    font-size: 0.85rem;
    font-weight: 400;
    text-decoration: none;
    border-bottom: 1px dashed var(--color-accent-purple);
    transition: all 0.2s;
  }
  .csdn-link:hover {
    color: var(--color-accent-deep);
    border-bottom-color: var(--color-accent-deep);
    text-decoration: none;
  }
  .post-list { display: flex; flex-direction: column; gap: 1rem; }
  .post-card {
    display: flex; gap: 1.5rem; align-items: flex-start;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-text);
    transition: all 0.3s var(--ease-out);
    box-shadow: var(--shadow-sm);
  }
  .post-card:hover {
    box-shadow: var(--shadow-hover);
    border-color: var(--color-accent);
    transform: translateX(3px);
    text-decoration: none;
    color: var(--color-text);
  }
  .post-date {
    display: flex; flex-direction: column; align-items: center;
    min-width: 3.5rem; flex-shrink: 0;
  }
  .post-day {
    font-family: var(--font-heading);
    font-size: 2rem; font-weight: 700;
    color: var(--color-accent-deep);
    line-height: 1;
  }
  .post-month {
    font-size: 0.7rem; color: var(--color-text-light);
    text-transform: uppercase; letter-spacing: 0.05em;
    margin-top: 0.25rem;
  }
  .post-info { flex: 1; min-width: 0; }
  .post-title {
    font-family: var(--font-body);
    font-size: 1.2rem; font-weight: 600;
    margin-bottom: 0.35rem;
  }
  .post-desc {
    color: var(--color-text-light); font-size: 0.9rem;
    margin-bottom: 0.5rem; line-height: 1.6;
  }
  .post-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .post-tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-accent-purple);
    background: rgba(184,169,212,0.1);
    padding: 0.15rem 0.5rem; border-radius: 4px;
  }
  @media (max-width: 480px) {
    .post-card { flex-direction: column; gap: 0.75rem; }
    .post-date { flex-direction: row; gap: 0.5rem; align-items: baseline; }
    .post-day { font-size: 1.5rem; }
  }
</style>
