---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ScrollReveal from '../../components/ScrollReveal.vue';

const posts = await getCollection('blog');
const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Base title="Blog" description="博客文章列表">
  <div class="content-container py-16">
    <!-- Page Header -->
    <ScrollReveal client:load>
      <h1 class="mb-2">Blog</h1>
      <p class="text-muted text-lg mb-12">文章是思想的化石。</p>
    </ScrollReveal>

    <!-- Post List -->
    <div class="flex flex-col">
      {
        sortedPosts.map((post, i) => (
          <ScrollReveal client:load delay={i * 0.1}>
            <article class="card card-hover mb-6">
              <a
                href={`/blog/${post.slug}`}
                class="no-underline! text-text hover:text-text"
              >
                <div class="flex flex-col sm:flex-row sm:items-start gap-6">
                  <!-- Date Badge -->
                  <div class="flex-shrink-0 text-center sm:text-left">
                    <time
                      class="font-heading text-accent font-900 text-3xl leading-none"
                      datetime={post.data.date.toISOString()}
                    >
                      {post.data.date.getDate()}
                    </time>
                    <div class="font-mono text-xs text-muted mt-1 uppercase">
                      {post.data.date.toLocaleDateString('zh-CN', {
                        month: 'short',
                        year: 'numeric',
                      })}
                    </div>
                  </div>

                  <!-- Title & Description -->
                  <div class="flex-1 min-w-0">
                    <h2 class="text-xl! mb-2 hover:text-accent transition-colors duration-200">
                      {post.data.title}
                    </h2>
                    <p class="text-muted m-0 text-sm leading-relaxed">
                      {post.data.description}
                    </p>

                    <!-- Tags -->
                    {
                      post.data.tags && post.data.tags.length > 0 && (
                        <div class="flex flex-wrap gap-1.5 mt-3">
                          {post.data.tags.map((tag) => (
                            <span class="text-xs font-mono text-muted border border-border px-2 py-0.5 rounded-sm">
                              #{tag}
                            </span>
                          ))}
                        </div>
                      )
                    }
                  </div>
                </div>
              </a>
            </article>
          </ScrollReveal>
        ))
      }
    </div>
  </div>
</Base>
