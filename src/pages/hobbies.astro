---
import Base from '../layouts/Base.astro';
import ScrollReveal from '../components/ScrollReveal.vue';

const hobbies = [
  { title: '足球', slug: 'football', desc: '绿茵场上奔跑，团队配合的快感无与伦比。', icon: '⚽', color: '#7EB8DA' },
  { title: '游戏', slug: 'gaming', desc: '从主机到 PC，游戏是另一种探索世界的方式。', icon: '🎮', color: '#D4A5C4' },
  { title: '编码', slug: 'opensource', desc: '写点小项目，享受从零到一的创造。', icon: '💻', color: '#B8A9D4' },
  { title: '徒步', slug: 'hiking', desc: '山野之间是最好的冥想空间。', icon: '🥾', color: '#5A9FC0' },
  { title: '音乐', slug: 'music', desc: '吉他、合成器、以及无尽的播放列表。', icon: '🎸', color: '#C4A8D0' },
];
---

<Base title="Hobbies" description="我的爱好">
  <div class="content-container py-16">
    <div class="page-header">
      <h1>Hobbies</h1>
      <p>学习之外，这些皆是我热爱的事。</p>
    </div>

    <div class="hobby-grid">
      {hobbies.map((h, i) => (
        <ScrollReveal client:load delay={i * 0.06}>
          <a href={`/hobbies/${h.slug}`} class="hobby-card">
            <div class="hobby-icon" style={`background: ${h.color}15; color: ${h.color}`}>
              {h.icon}
            </div>
            <h3>{h.title}</h3>
            <p>{h.desc}</p>
            <span class="hobby-arrow">→</span>
          </a>
        </ScrollReveal>
      ))}
    </div>
  </div>
</Base>

<style>
  .page-header { margin-bottom: 3rem; }
  .page-header h1 { margin-bottom: 0.3rem; }
  .page-header p { color: var(--color-text-light); font-size: 1.1rem; font-weight: 300; }
  .hobby-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1.25rem;
  }
  .hobby-card {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    text-align: center;
    text-decoration: none;
    color: var(--color-text);
    transition: all 0.3s var(--ease-out);
    box-shadow: var(--shadow-sm);
    position: relative;
    overflow: hidden;
  }
  .hobby-card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-2px);
    border-color: var(--color-accent);
    text-decoration: none;
    color: var(--color-text);
  }
  .hobby-icon {
    width: 3.5rem; height: 3.5rem;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.8rem;
    margin: 0 auto 1rem;
  }
  .hobby-card h3 {
    font-family: var(--font-body);
    font-size: 1rem; font-weight: 600;
    margin-bottom: 0.4rem;
  }
  .hobby-card p {
    font-size: 0.85rem; color: var(--color-text-light);
    line-height: 1.6; margin: 0;
    font-weight: 300;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .hobby-arrow {
    display: inline-block; margin-top: 0.75rem;
    font-size: 0.85rem; color: var(--color-accent);
    opacity: 0; transform: translateX(-4px);
    transition: all 0.25s var(--ease-out);
  }
  .hobby-card:hover .hobby-arrow {
    opacity: 1; transform: translateX(0);
  }
</style>
