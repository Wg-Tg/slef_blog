---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import NotesFilter from '../../components/NotesFilter.vue';

const rawNotes = await getCollection('notes');
const notes = rawNotes.map((n) => ({
  slug: n.id,
  data: {
    ...n.data,
    date: n.data.date.toISOString(),
    // 合并 frontmatter content + body 内容
    content: n.data.content || '',
    bodyHtml: n.rendered?.html || '',
  },
}));
---

<Base title="Notes" description="碎片分享">
  <div class="content-container py-16">
    <div class="page-header">
      <h1>Notes</h1>
      <p>碎片化的思考，像星光一样散落。</p>
    </div>
    <NotesFilter client:load notes={notes} />
  </div>
</Base>

<style>
  .page-header { margin-bottom: 2.5rem; }
  .page-header h1 { margin-bottom: 0.3rem; }
  .page-header p { color: var(--color-text-light); font-size: 1.1rem; font-weight: 300; }
</style>
