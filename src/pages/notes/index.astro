---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import NotesFilter from '../../components/NotesFilter.vue';

const rawNotes = await getCollection('notes');

// Serialize notes for Vue component (dates become ISO strings)
const notes = rawNotes.map((n) => ({
  slug: n.slug,
  data: {
    ...n.data,
    date: n.data.date.toISOString(),
    content: n.data.content || '',
  },
}));
---

<Base title="Notes" description="碎片分享流 — 随想、灵感和发现">
  <div class="content-container py-16">
    <!-- Page Header -->
    <h1 class="mb-2">Notes</h1>
    <p class="text-muted text-lg mb-12">碎片化的思考，像星光一样散落。</p>

    <!-- Notes Filter (client:load for interactivity, but notes data is server-rendered) -->
    <NotesFilter client:load notes={notes} />
  </div>
</Base>
