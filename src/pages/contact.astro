---
import Base from '../layouts/Base.astro';
import ScrollReveal from '../components/ScrollReveal.vue';

const web3formsKey = 'ffeed187-ca23-46e3-9f34-ca2a1f82b85d';
---

<Base title="Contact" description="联系我">
  <div class="content-container py-16">
    <ScrollReveal client:load>
      <h1 class="mb-2">Contact</h1>
      <p class="text-muted text-lg mb-12">有话说？写下来，发给我。</p>
    </ScrollReveal>

    <ScrollReveal client:load delay={0.1}>
      <div class="card max-w-lg">
        <form
          action={`https://api.web3forms.com/submit`}
          method="POST"
          class="flex flex-col gap-5"
        >
          <!-- Web3Forms Access Key -->
          <input type="hidden" name="access_key" value={web3formsKey} />
          <input type="hidden" name="subject" value="New Contact from My Space" />
          <input type="hidden" name="from_name" value="My Space Contact Form" />

          <!-- Honeypot (anti-spam) -->
          <input type="checkbox" name="botcheck" class="hidden" style="display:none;" tabindex="-1" autocomplete="off" />

          <!-- Name -->
          <div>
            <label for="name" class="block font-heading text-sm font-700 mb-2">
              Name
            </label>
            <input
              type="text"
              name="name"
              id="name"
              required
              placeholder="Your name"
              class="w-full input"
            />
          </div>

          <!-- Email -->
          <div>
            <label for="email" class="block font-heading text-sm font-700 mb-2">
              Email
            </label>
            <input
              type="email"
              name="email"
              id="email"
              required
              placeholder="your@email.com"
              class="w-full input"
            />
          </div>

          <!-- Message -->
          <div>
            <label for="message" class="block font-heading text-sm font-700 mb-2">
              Message
            </label>
            <textarea
              name="message"
              id="message"
              required
              rows={5}
              placeholder="Write your message..."
              class="w-full input resize-y"
            ></textarea>
          </div>

          <!-- Redirect after success -->
          <input type="hidden" name="redirect" value={`${Astro.url.origin}/contact?success=true`} />

          <!-- Submit Button -->
          <button
            type="submit"
            class="btn self-start font-heading text-sm"
            id="contact-submit"
          >
            Send Message
          </button>
        </form>
      </div>
    </ScrollReveal>

    <!-- Success Message -->
    {
      Astro.url.searchParams.get('success') === 'true' && (
        <div class="card mt-8 max-w-lg" style="border-color: var(--color-accent-alt, #F4A261);">
          <p class="text-lg font-heading font-700 m-0">
            Message sent!
          </p>
          <p class="text-muted mt-2 m-0">
            Thanks for reaching out. I'll get back to you soon.
          </p>
        </div>
      )
    }
  </div>
</Base>

<!-- GSAP Button Press Animation -->
<script>
  if (typeof window !== 'undefined') {
    import('gsap').then(({ default: gsap }) => {
      const btn = document.getElementById('contact-submit');
      if (!btn) return;

      btn.addEventListener('mousedown', () => {
        gsap.to(btn, {
          scale: 0.96,
          duration: 0.1,
          ease: 'power2.in',
        });
      });

      btn.addEventListener('mouseup', () => {
        gsap.to(btn, {
          scale: 1,
          duration: 0.2,
          ease: 'power2.out',
        });
      });

      btn.addEventListener('mouseleave', () => {
        gsap.to(btn, {
          scale: 1,
          duration: 0.15,
          ease: 'power2.out',
        });
      });
    });
  }
</script>
